# Database
# Default local DB (safe for local/dev)
DATABASE_URL=sqlite+aiosqlite:///./alysha_booking.db
# Example PostgreSQL DSN (uncomment and adjust for live DB)
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<db_name>

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_VALIDATE_SIGNATURE=true

# App
APP_ENV=development
SECRET_KEY=
LOG_LEVEL=INFO

# Worker seed
DEFAULT_WORKER_NAME=Alysha
DEFAULT_WORKER_TIMEZONE=Europe/London
